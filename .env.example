# --- OpenAI ---
# Credencial secreta: OPENAI_API_KEY
# El resto del bloque configura endpoint y conexión.

OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=
OPENAI_CONNECT_TIMEOUT_SECONDS=15

# --- Aplicación y logging ---
LOG_LEVEL=INFO
LOG_JSON=false
MAX_TOOL_ROUNDS=8

# --- Redis y contexto de conversaciones ---
# REDIS_URL puede incluir una contraseña en despliegues remotos.
REDIS_URL=redis://localhost:6379/0
CONVERSATION_TTL_SECONDS=604800
CONVERSATION_MAX_MESSAGES=100
CONVERSATION_MAX_CHARACTERS=200000
CONVERSATION_MAX_BYTES=512000

# --- Gemini ---
# Credencial secreta: GEMINI_API_KEY
GEMINI_API_KEY=your-gemini-key-here

# --- Agentes y proveedores independientes ---
TEXT_AGENT_PROVIDER=openai
TEXT_AGENT_MODEL=gpt-5-mini
REALTIME_AGENT_PROVIDER=gemini
REALTIME_AGENT_MODEL=gemini-3.1-flash-live-preview
WORKER_PROVIDER=openai
WORKER_AGENT_MODEL=gpt-5-mini

# --- Gemini Live ---
GEMINI_LIVE_API_VERSION=v1beta
GEMINI_LIVE_VOICE_NAME=Zephyr
GEMINI_LIVE_LANGUAGE_CODE=

# --- Audio en tiempo real ---
REALTIME_AUDIO_MAX_CHUNK_BYTES=32768
REALTIME_SESSION_MAX_SECONDS=1800
REALTIME_OUTBOUND_MAX_MESSAGES=128
REALTIME_OUTBOUND_MAX_AUDIO_BYTES=131072
REALTIME_OUTBOUND_ENQUEUE_TIMEOUT_SECONDS=5
REALTIME_RESUMPTION_MAX_ATTEMPTS=3
REALTIME_RESUMPTION_TIMEOUT_SECONDS=15
REALTIME_PROACTIVE_TURN_TIMEOUT_SECONDS=120
REALTIME_COMMAND_RECONCILIATION_SECONDS=5

# --- PostgreSQL ---
# POSTGRES_URL contiene la conexión y puede incluir usuario y contraseña.
POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/tesseraflow
POSTGRES_POOL_MIN_SIZE=1
POSTGRES_POOL_MAX_SIZE=10
POSTGRES_COMMAND_TIMEOUT_SECONDS=30

# --- Worker A2A ---
A2A_WORKER_RECONCILIATION_SECONDS=5
A2A_JOB_TIMEOUT_SECONDS=600

# --- Coordinación de interacciones ---
INTERACTION_COORDINATOR_RECONCILIATION_SECONDS=5
INTERACTION_OUTPUT_RECONCILIATION_SECONDS=5
INTERACTION_COMMAND_TIMEOUT_SECONDS=120
INTERACTION_MAX_PENDING_COMMANDS=16
INTERACTION_COORDINATOR_WORKERS=4
